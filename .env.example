# AI-Sailing configuratie. Kopieer naar .env en pas aan.
# Er zijn GEEN verplichte secrets: Open-Meteo werkt zonder API-key.

# Poort van de webserver.
PORT=3000

# Forecast-cache (in-memory).
FORECAST_CACHE_TTL_MS=1800000   # 30 minuten
FORECAST_CACHE_MAX=50           # max aantal gecachte velden

# Rate limiting op /api/route (per IP).
RATE_LIMIT_MAX=30               # max verzoeken per venster
RATE_LIMIT_WINDOW_MS=60000      # venster in ms

# Optionele beveiliging: als gezet, vereist /api/route de header "x-api-key".
# Leeg laten = endpoint openbaar.
# API_KEY=

# Veiligheidsplafond tegen extreem grote berekeningen.
MAX_ROUTE_NM=1500

# Logniveau: error | warn | info | debug
LOG_LEVEL=info
